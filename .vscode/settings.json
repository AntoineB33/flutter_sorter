{
  "cmake.ignoreCMakeListsMissing": true,
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true,
    "**/.dart_tool/**": true,
    "**/build/**": true
  },
  "search.exclude": {
    "**/build": true,
    "**/.dart_tool": true
  }
}
